{
    "name": "webplantmedia/gallop-wp",
    "description": "Headless WordPress plugin exposing custom post types via REST for a Next.js front end.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Gallop\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
